export const AreaCoverWhen = async <T>(
  runner: () => Promise<T> | T,
  targetElement: string | HTMLElement = 'body',
): Promise<Awaited<Promise<T> | T>> => {
  const loading = ElLoading.service({
    ...DEFAULT_OPTIONS,
    target: targetElement,
    fullscreen: true,
