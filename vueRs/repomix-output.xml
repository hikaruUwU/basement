<file path="src/util/pipeline.ts">
export class Pipeline<T> {
  private value: T;

  constructor(value: T) {
    this.value = value;
  }

  public then<R>(processor: (val: T) => R): Pipeline<R> {
    const nextValue = processor(this.value);
    return new Pipeline(nextValue);
  }

  public valueOf(): T {
    return this.value;
  }
}

export const pipeline = <T>(source: T) => new Pipeline(source);
</file>

